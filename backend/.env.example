# ── Application ──
APP_NAME=competitive-analysis-backend
APP_ENV=development
APP_DEBUG=true
APP_PORT=8000
APP_HOST=0.0.0.0

# ── Database ──
DATABASE_URL=sqlite+aiosqlite:///./data/competitive_analysis.db

# ── LLM Configuration ──
# Provider: mock | openai | anthropic
LLM_PROVIDER=mock

# OpenAI — set these when LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Logging ──
LOG_LEVEL=INFO
LOG_FORMAT=json

# ── Workflow ──
WORKFLOW_MAX_DURATION_SECONDS=300
WORKFLOW_MAX_RETRIES=3
WORKFLOW_HITL_ENABLED=false
