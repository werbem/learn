# Application
APP_NAME=competitive-analysis-backend
APP_ENV=development
APP_DEBUG=true
APP_PORT=8000
APP_HOST=0.0.0.0

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/competitive_analysis.db
DATABASE_ECHO=false

# Redis
REDIS_URL=redis://localhost:6379/0

# LLM — set LLM_PROVIDER=openai and provide your API key to use real LLM
LLM_PROVIDER=mock
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Workflow
WORKFLOW_MAX_DURATION_SECONDS=300
WORKFLOW_MAX_RETRIES=3
WORKFLOW_HITL_ENABLED=false
