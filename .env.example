# ============================================================
# AI 竞品分析助手 — 环境变量模板
# 复制此文件为 .env 并填入真实值
#   cp .env.example .env
# ============================================================

# ── 应用配置 ──
APP_NAME=competitive-analysis-backend
APP_ENV=development
APP_DEBUG=true
APP_PORT=8000
APP_HOST=0.0.0.0

# ── LLM 配置 ──
# 可选: openai | mock
LLM_PROVIDER=openai
# OpenAI API Key（支持 DeepSeek 等兼容 API）
# 填入你的 key 以启用真实 AI 模式，留空则自动运行 Demo 模式
OPENAI_API_KEY=sk-your-key-here
# 模型名称 (gpt-4o-mini / gpt-4o / deepseek-chat)
OPENAI_MODEL=gpt-4o-mini
# 自定义 API Base URL（使用 DeepSeek 等第三方时填写）
# OPENAI_BASE_URL=https://api.deepseek.com

# ── 搜索配置 ──
# Tavily Search API Key（https://tavily.com）
# 填入你的 key 以启用真实搜索，留空则使用模拟数据
TAVILY_API_KEY=tvly-your-key-here

# ── 数据库配置 ──
DATABASE_URL=sqlite+aiosqlite:///./data/competitive_analysis.db

# ── 前端地址（用于 CORS，公网部署时改为实际域名） ──
FRONTEND_URL=http://localhost:3000

# ── 前端 API 地址 ──
# 默认留空，浏览器使用相对路径（推荐，适合内网穿透）
# 如需直连后端，设置为后端地址，例如 http://localhost:8000
# NEXT_PUBLIC_API_URL=http://localhost:8000

# ── 工作流配置 ──
WORKFLOW_MAX_DURATION_SECONDS=300
WORKFLOW_MAX_RETRIES=3

# ── Demo 模式 ──
# 不设置时自动检测：有 API Key → 真实模式，无 Key → Demo 模式
# 显式设置 true 可强制 Demo 模式
# DEMO_MODE=false

# ── 日志配置 ──
LOG_LEVEL=INFO
LOG_FORMAT=json
