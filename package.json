{
  "name": "competitive-analysis",
  "version": "1.0.0",
  "private": true,
  "description": "AI 竞品分析助手 — 自动生成互联网产品竞品分析报告",
  "scripts": {
    "backend:install": "cd backend && pip install -r requirements.txt",
    "backend:dev": "cd backend && python -m uvicorn app.main:app --reload --host 127.0.0.1 --port 8000",
    "backend:start": "cd backend && python -m uvicorn app.main:app --host 127.0.0.1 --port 8000",
    "backend:test": "cd backend && python -m pytest tests/ -v",
    "frontend:install": "cd frontend && pnpm install",
    "frontend:dev": "cd frontend && pnpm dev",
    "frontend:build": "cd frontend && pnpm build",
    "frontend:start": "cd frontend && pnpm start",
    "install:all": "npm run backend:install && npm run frontend:install",
    "dev": "concurrently -n backend,frontend -c blue,green \"npm run backend:dev\" \"npm run frontend:dev\"",
    "start": "concurrently -n backend,frontend -c blue,green \"npm run backend:start\" \"npm run frontend:start\"",
    "build": "npm run frontend:build",
    "test": "npm run backend:test",
    "clean": "rm -rf frontend/.next frontend/node_modules backend/__pycache__ data/*.db"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
